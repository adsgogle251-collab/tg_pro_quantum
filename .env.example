# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="TG Pro Quantum"
APP_VERSION="7.0.0"
DEBUG=false
SECRET_KEY="change-me-in-production-use-a-long-random-string"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/tg_pro_quantum"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY="jwt-secret-change-in-production-use-a-long-random-string"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMS Activate ──────────────────────────────────────────────────────────────
SMS_ACTIVATE_API_KEY=""
SMS_ACTIVATE_BASE_URL="https://api.sms-activate.org/stubs/handler_api.php"

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=""

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list encoded as JSON array
ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

# ── Email (optional SMTP) ─────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAILS_FROM="noreply@tgproquantum.com"
