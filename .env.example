# ── TG PRO QUANTUM - Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in your values

# Application
APP_NAME=TG PRO QUANTUM
APP_VERSION=7.0.0
DEBUG=false
SECRET_KEY=your-secret-key-min-32-chars-change-in-production

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tg_quantum

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP / SMS Activate
SMS_ACTIVATE_API_KEY=your_sms_activate_api_key
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Telegram (default API credentials for the service)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_telegram_api_hash

# Broadcast defaults
DEFAULT_DELAY_MIN=3.0
DEFAULT_DELAY_MAX=8.0
MAX_RETRIES=3

# Email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@tgquantum.io

# CORS
ALLOWED_HOSTS=["*"]
