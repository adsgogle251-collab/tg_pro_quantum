# ─────────────────────────────────────────────────────────────────────────────
# TG PRO QUANTUM – Production Environment Variables
# Copy this file to .env.production and fill in real values.
# NEVER commit the populated file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_64
ALLOWED_HOSTS=api.tg-pro-quantum.app,app.tg-pro-quantum.app

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tgpq_prod:CHANGE_ME@db-primary:5432/tg_quantum_prod
POSTGRES_DB=tg_quantum_prod
POSTGRES_USER=tgpq_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=CHANGE_ME_REPLICATION_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis-1:6379/0
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
CELERY_BROKER_URL=redis://:CHANGE_ME@redis-1:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME@redis-1:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://app.tg-pro-quantum.app,https://api.tg-pro-quantum.app

# ── WebSocket ─────────────────────────────────────────────────────────────────
WEBSOCKET_URL=wss://api.tg-pro-quantum.app/ws

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/app/logs/app.log

# ── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
METRICS_PATH=/metrics
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch-1:9200
ELASTICSEARCH_PASSWORD=CHANGE_ME_ELASTICSEARCH_PASSWORD

# ── Security ──────────────────────────────────────────────────────────────────
TLS_MIN_VERSION=TLSv1.3
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
SESSION_EXPIRE_SECONDS=86400

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BURST=20
AUTH_RATE_LIMIT_PER_MINUTE=10

# ── S3 Backups ────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_DEFAULT_REGION=ap-southeast-1
S3_BACKUP_BUCKET=tgpq-prod-backups

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
PAGERDUTY_INTEGRATION_KEY=CHANGE_ME
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@tg-pro-quantum.app
SMTP_PASSWORD=CHANGE_ME
ALERT_EMAIL_TO=team@tg-pro-quantum.app

# ── Blue/Green Deployment ─────────────────────────────────────────────────────
BLUE_IMAGE_TAG=latest
GREEN_IMAGE_TAG=green
DEPLOY_COLOR=blue

# ── Image Registry ────────────────────────────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/adsgogle251-collab/tg_pro_quantum
