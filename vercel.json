{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "cd frontend && npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "VITE_API_URL": "https://tg-pro-quantum.onrender.com/api/v1",
    "VITE_WS_URL": "https://tg-pro-quantum.onrender.com"
  }
}
